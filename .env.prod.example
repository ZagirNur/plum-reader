# Production env for docker-compose.prod.yml.
# Copy to `.env` on the host and fill in the secrets.

# --- Domain / TLS ---
DOMAIN=plum.zagirnur.dev
ACME_EMAIL=zagirnur@gmail.com

# --- Postgres ---
POSTGRES_DB=plum_reader
POSTGRES_USER=plum
# CHANGE ME. Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=__CHANGE_ME__

# --- JWT ---
# Must be >= 32 bytes. Generate with: openssl rand -base64 48
PLUM_JWT_SECRET=__CHANGE_ME__
PLUM_JWT_EXPIRATION_MINUTES=60

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Native iOS/Android apps don't need this; the web client does.
# Leave empty for same-origin only.
PLUM_CORS_ALLOWED_ORIGINS=
